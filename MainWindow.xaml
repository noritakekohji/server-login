<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="server-login"
        Width="620"
        Height="118"
        MinWidth="520"
        MinHeight="112"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#EEF2F7"
        FontFamily="Meiryo UI">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#182230" />
        <SolidColorBrush x:Key="MutedBrush" Color="#697586" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F7B8A" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#0B6673" />

        <Style x:Key="LauncherButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#243244" />
            <Setter Property="BorderBrush" Value="#3B4A5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#304158" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#52637A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#172235" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#084F59" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" BasedOn="{StaticResource LauncherButtonStyle}" TargetType="{x:Type Button}" />
        <Style x:Key="CompactActionButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}" TargetType="{x:Type Button}" />
        <Style x:Key="ColorActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#B7C2D0" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RdpActionButtonStyle" BasedOn="{StaticResource ColorActionButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#EAF1FF" />
            <Setter Property="BorderBrush" Value="#93B4F8" />
            <Setter Property="Foreground" Value="#1D4ED8" />
        </Style>
        <Style x:Key="SshActionButtonStyle" BasedOn="{StaticResource ColorActionButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#E6F7F4" />
            <Setter Property="BorderBrush" Value="#76BEB7" />
            <Setter Property="Foreground" Value="#0F766E" />
        </Style>
        <Style x:Key="SftpActionButtonStyle" BasedOn="{StaticResource ColorActionButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#F1EAFF" />
            <Setter Property="BorderBrush" Value="#BCA3F5" />
            <Setter Property="Foreground" Value="#6D28D9" />
            <Setter Property="MinWidth" Value="34" />
        </Style>

        <Style x:Key="FieldStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="Foreground" Value="#405166" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDF4F7" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlainPasswordUserCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasPlainPassword}" Value="True">
                    <Setter Property="Background" Value="#FFF3BF" />
                    <Setter Property="ToolTip" Value="平文パスワードが保存されています。ユーザーセルをダブルクリックすると暗号化してYAMLを書き換えます。" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDF4F7" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasPlainPassword}" Value="True" />
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FDE68A" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172233" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="server-login" Foreground="#F8FAFC" FontSize="16" FontWeight="Bold" />
                    <TextBlock x:Name="ServerListPathText"
                               Foreground="#9AA8BA"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="OpenListButton" Style="{StaticResource LauncherButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE839;" Margin="0,0,6,0" />
                            <TextBlock Text="サーバ接続" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="OpenLogButton" Style="{StaticResource LauncherButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Margin="0,0,6,0" />
                            <TextBlock Text="ログ" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CaptureScreenshotButton" Style="{StaticResource LauncherButtonStyle}" ToolTip="Ctrl+Alt+S">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE722;" Margin="0,0,6,0" />
                            <TextBlock Text="記録" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsButton" Style="{StaticResource LauncherButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Margin="0,0,6,0" />
                            <TextBlock Text="設定" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshButton" Content="更新" Style="{StaticResource LauncherButtonStyle}" Visibility="Collapsed" />
                    <Button x:Name="EncryptPasswordButton" Content="暗号化" Style="{StaticResource LauncherButtonStyle}" Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ServerPanel"
                Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="8"
                Padding="8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="サーバ接続" Foreground="{StaticResource InkBrush}" FontSize="14" FontWeight="Bold" />
                        <TextBlock x:Name="CountText" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                    </StackPanel>
                    <Button x:Name="EditServerListButton"
                            Grid.Column="1"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Foreground="{StaticResource InkBrush}"
                            Background="#F7F9FC"
                            BorderBrush="{StaticResource LineBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" Margin="0,0,5,0" />
                            <TextBlock Text="一覧編集" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CloseServerPanelButton"
                            Grid.Column="2"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Foreground="{StaticResource InkBrush}"
                            Background="#F7F9FC"
                            BorderBrush="{StaticResource LineBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,5,0" />
                            <TextBlock Text="閉じる" />
                        </StackPanel>
                    </Button>
                </Grid>

                <DataGrid x:Name="ServerGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          MinRowHeight="28"
                          ColumnHeaderHeight="30"
                          Background="#FFFFFF"
                          Foreground="{StaticResource InkBrush}"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionUnit="FullRow"
                          HorizontalGridLinesBrush="#EDF1F6"
                          VerticalGridLinesBrush="#EDF1F6">
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Setter Property="Background" Value="#FFFFFF" />
                            <Setter Property="BorderBrush" Value="#EDF1F6" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1FAFB" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DDF4F7" />
                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="接続" Width="108">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="RDP" Tag="RDP" IsEnabled="{Binding CanRdp}" Style="{StaticResource RdpActionButtonStyle}" />
                                        <Button Content="SSH" Tag="SSH" IsEnabled="{Binding CanSsh}" Style="{StaticResource SshActionButtonStyle}" />
                                        <Button Content="SFTP" Tag="SFTP" IsEnabled="{Binding CanSftp}" Style="{StaticResource SftpActionButtonStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ホスト" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Border x:Name="OsBadge"
                                                Width="28"
                                                Height="16"
                                                Background="#F1F5F9"
                                                BorderBrush="#CBD5E1"
                                                BorderThickness="1"
                                                CornerRadius="0"
                                                Margin="0,0,8,0">
                                            <TextBlock x:Name="OsBadgeText"
                                                       Text="OS"
                                                       Foreground="#64748B"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource GridTextBlockStyle}" />
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding OSFamily}" Value="Windows">
                                            <Setter TargetName="OsBadge" Property="Background" Value="#EAF1FF" />
                                            <Setter TargetName="OsBadge" Property="BorderBrush" Value="#93B4F8" />
                                            <Setter TargetName="OsBadgeText" Property="Text" Value="WIN" />
                                            <Setter TargetName="OsBadgeText" Property="Foreground" Value="#1D4ED8" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OSFamily}" Value="Linux">
                                            <Setter TargetName="OsBadge" Property="Background" Value="#E6F7F4" />
                                            <Setter TargetName="OsBadge" Property="BorderBrush" Value="#76BEB7" />
                                            <Setter TargetName="OsBadgeText" Property="Text" Value="LNX" />
                                            <Setter TargetName="OsBadgeText" Property="Foreground" Value="#0F766E" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="接続先" Binding="{Binding EffectiveHost}" Width="150" ElementStyle="{StaticResource GridTextBlockStyle}" />
                        <DataGridTemplateColumn Header="ユーザー" Width="120" CellStyle="{StaticResource PlainPasswordUserCellStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="PlainPasswordIcon"
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,5,0"
                                                Background="#F59E0B"
                                                BorderBrush="#D97706"
                                                BorderThickness="1"
                                                Visibility="Collapsed">
                                            <TextBlock Text="!"
                                                       Foreground="#FFFFFF"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,-1,0,0" />
                                        </Border>
                                        <TextBlock Text="{Binding User}" Style="{StaticResource GridTextBlockStyle}" />
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasPlainPassword}" Value="True">
                                            <Setter TargetName="PlainPasswordIcon" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="環境" Binding="{Binding Environment}" Width="90" ElementStyle="{StaticResource GridTextBlockStyle}" />
                        <DataGridTextColumn Header="備考" Binding="{Binding Note}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Visibility="Collapsed">
            <TextBox x:Name="SearchBox" />
            <ComboBox x:Name="EnvFilterCombo" />
            <TextBlock x:Name="DetailNameText" />
            <TextBlock x:Name="DetailInfoText" />
            <Border x:Name="WarningPanel" />
            <TextBlock x:Name="WarningText" />
            <Button x:Name="ConnectRdpButton" />
            <Button x:Name="ConnectSshButton" />
            <Button x:Name="ConnectSftpButton" />
        </StackPanel>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="8,4">
            <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="{StaticResource MutedBrush}" FontSize="11" />
        </Border>
    </Grid>
</Window>
