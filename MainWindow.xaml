<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="server-login"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        FontFamily="Meiryo UI">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#182230" />
        <SolidColorBrush x:Key="MutedBrush" Color="#697586" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F7B8A" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#0B6673" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#E7F5F7" />
        <SolidColorBrush x:Key="DangerBrush" Color="#BA3A2B" />

        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#243244" />
            <Setter Property="BorderBrush" Value="#3B4A5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#304158" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#52637A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#172235" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#084F59" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactActionButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="Foreground" Value="#405166" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDF4F7" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="LineHeight" Value="18" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172233" Padding="18,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="server-login" Foreground="#F8FAFC" FontSize="22" FontWeight="Bold" />
                    <TextBlock x:Name="ServerListPathText"
                               Foreground="#9AA8BA"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Content="更新" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button x:Name="SettingsButton" Content="設定" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button x:Name="OpenListButton" Content="サーバ一覧を開く" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button x:Name="EncryptPasswordButton"
                            Content="パスワード暗号化"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="パスワードを DPAPI で暗号化して YAML に貼り付けられる文字列を生成" />
                </StackPanel>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#223047" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="検索" Foreground="#CAD5E3" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="SearchBox" Grid.Column="1" Style="{StaticResource FieldStyle}" />
                        <TextBlock Grid.Column="2" Text="環境" Foreground="#CAD5E3" VerticalAlignment="Center" Margin="18,0,8,0" />
                        <ComboBox x:Name="EnvFilterCombo" Grid.Column="3" Style="{StaticResource ComboStyle}" />
                        <TextBlock x:Name="CountText"
                                   Grid.Column="5"
                                   Foreground="#F8FAFC"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="392" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="16,14,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="サーバ一覧" Foreground="{StaticResource InkBrush}" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="接続先、権限、環境をすばやく確認" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="ServerGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              MinRowHeight="30"
                              ColumnHeaderHeight="40"
                              Background="#FFFFFF"
                              Foreground="{StaticResource InkBrush}"
                              BorderThickness="0"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionUnit="FullRow"
                              AlternatingRowBackground="#F8FAFC"
                              HorizontalGridLinesBrush="#EDF1F6"
                              VerticalGridLinesBrush="#EDF1F6"
                              Margin="1,0,1,1">
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Setter Property="BorderBrush" Value="#EDF1F6" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1FAFB" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DDF4F7" />
                                        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ホスト名" Binding="{Binding Name}" Width="170" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="OS" Binding="{Binding OS}" Width="70" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="IP/接続先" Binding="{Binding EffectiveHost}" Width="140" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="ユーザ" Binding="{Binding User}" Width="120" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="環境" Binding="{Binding Environment}" Width="80" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="権限" Binding="{Binding Role}" Width="80" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="開発中" Binding="{Binding DevelopmentLabel}" Width="70" ElementStyle="{StaticResource GridTextBlockStyle}" />
                            <DataGridTextColumn Header="備考" Binding="{Binding Note}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="14,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="選択中サーバ" Style="{StaticResource SectionLabelStyle}" />
                    <TextBlock Grid.Row="1"
                               x:Name="DetailNameText"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,6,0,10"
                               TextWrapping="Wrap" />

                    <Border Grid.Row="2" Background="#F7F9FC" BorderBrush="#E4EAF2" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <TextBlock x:Name="DetailInfoText"
                                   Foreground="#36475C"
                                   LineHeight="22"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="3"
                            x:Name="WarningPanel"
                            Background="#FFF5E6"
                            BorderBrush="#E9A23B"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="WarningText" TextWrapping="Wrap" Foreground="#8A4F00" />
                    </Border>

                    <StackPanel Grid.Row="4" Orientation="Vertical" VerticalAlignment="Top">
                        <TextBlock Text="接続アクション" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ConnectRdpButton" Content="RDP" Style="{StaticResource CompactActionButtonStyle}" />
                            <Button x:Name="ConnectSshButton" Content="SSH" Style="{StaticResource CompactActionButtonStyle}" />
                            <Button x:Name="ConnectSftpButton" Content="SFTP" Style="{StaticResource CompactActionButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="14,8">
            <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
